            <li><a href="/documents/protocols/Årsmöte 2025pdf.pdf">Annual Meeting 2025</a> 2025-04-23</li>
            <li><a href="/documents/protocols/Annual meeting 2024.pdf">Annual Meeting 2024</a> 2024-04-19</li>
            <li><a href="/documents/protocols/CASE_årsmöte_2023.pdf">Annual Meeting 2023</a> 2023-05-12</li>
            <li><a href="/documents/protocols/CASE_årsmöte_2022.pdf">Annual Meeting 2022</a> 2022-05-16</li>
