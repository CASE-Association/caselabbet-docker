---
import "/src/styles/global.css";
---

<div id="header">
    <a href="/" class="logo">C.A.S.E</a>
    <div id="navlinks">
        <!-- <a class="desktop-only"><span>The Association</span></a> -->
        <a href="/join" id="become-member"><b>Join</b></a>
        <div class="dropdown">
            <div class="dropdown-button">
            <svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="0 0 24 24"><g fill="none"><path d="m12.593 23.258l-.011.002l-.071.035l-.02.004l-.014-.004l-.071-.035q-.016-.005-.024.005l-.004.01l-.017.428l.005.02l.01.013l.104.074l.015.004l.012-.004l.104-.074l.012-.016l.004-.017l-.017-.427q-.004-.016-.017-.018m.265-.113l-.013.002l-.185.093l-.01.01l-.003.011l.018.43l.005.012l.008.007l.201.093q.019.005.029-.008l.004-.014l-.034-.614q-.005-.018-.02-.022m-.715.002a.02.02 0 0 0-.027.006l-.006.014l-.034.614q.001.018.017.024l.015-.002l.201-.093l.01-.008l.004-.011l.017-.43l-.003-.012l-.01-.01z"/><path fill="var(--white)" d="M20 17.5a1.5 1.5 0 0 1 .144 2.993L20 20.5H4a1.5 1.5 0 0 1-.144-2.993L4 17.5zm0-7a1.5 1.5 0 0 1 0 3H4a1.5 1.5 0 0 1 0-3zm0-7a1.5 1.5 0 0 1 0 3H4a1.5 1.5 0 1 1 0-3z"/></g></svg>
            </div>
            <div class="dropdown-content">
                <table id="menutable">
                    <tr>
                        <td>
                            <h3>Association</h3>
                            <ul>
                                <li><a href="/board">The Board</a></li>
                                <li><a href="/contact">Contact</a></li>
                                <li><a href="https://discord.gg/RTsXRPZzaj">Discord</a></li>
                                <li><a href="https://github.com/case-association">GitHub</a></li>
                                <li><a href="/documents">Documents</a></li>
                                <li><a href="/asp">Aspning</a></li>
                            </ul>
                        </td>
                        <td>
                            <h3>Member Info</h3>
                            Inventory
                            <ul>
                                <li><a href="/components">Components</a></li>
                                <!--<li><a href="/equipment">Equipment</a></li>-->

                            </ul>
                            Resources
                            <ul>
                                <li><a href="https://booked.caselabbet.se/">Booking</a></li>
                                <li><a href="/courses">Courses</a></li>
                                <li><a href="/faq">FAQ</a></li>
                            </ul>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    let buttons = document.getElementsByClassName("dropdown-button");
    for(let i = 0; i < buttons.length; i++){
        buttons[i].onclick = () => {
            buttons[i].parentElement.classList.toggle("extended");
        };
    }

</script>


<style>
    #header{
        display: flex;
        background-color: var(--grey);
        color:white;
    }

    #header a{
        text-decoration:none;
    }

    #header a:visited{
        color: inherit;
    }

    @media (max-width:45em){
        #navlinks .desktop-only{
            display:none;
        }
    }

    @media (min-width:45em){
        #navlinks .mobile-only{
            display:none;
        }
    }

    #navlinks{
        display: flex;
        /* display:inline-block; */
        margin-left:auto;
        /* vertical-align:center; */
    }

    #navlinks > *{
        display:flex;
        /* color: var(--case-red); */
        color: white;
    }

    #become-member{
        align-items:center;
        padding: 0px 30px 0px 30px;
    }


    .logo{
        font-family: Pirulen;
        font-size: 1.5em;
        padding: 0.5em;
        padding-left: 1em;
        padding-right: 1em;
        width: min-content;
        color: white;
    }

    #become-member{
        background-color: var(--case-red);
        color: white;
        text-align: center;
    }

    .dropdown{
        position: relative;
        aspect-ratio: 1;
    }

    .dropdown-button{
        margin: 0;
        padding: 1em;
    }


    .dropdown-content{
        display:none;
        position:absolute;
        background-color: var(--light-grey);
        z-index: 1;
        box-shadow: 0px 0px 5px #222;
    }

    .extended .dropdown-content{
        display:block;
        top:100%;
        right:0%;
    }

    #menutable tr{
        vertical-align: top;
    }

    #menutable td{
        width: 40em;
        padding: 20px;
    }

    #menutable ul{
        padding-left: 10px;
        list-style: none;
        margin-top: 0;
    }

    #menutable td a{
        color: var(--case-red);
    }

    #menutable h3{
        margin: 0;
        white-space: nowrap;
    }

    #menutable h4{
    }

    Button{
        background-color: black;
    }


</style>
