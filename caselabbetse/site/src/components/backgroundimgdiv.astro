---
const {url = "missingparameter.png"} = Astro.props;
import {Image} from "astro:assets";
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/img/**/*.{jpeg,jpg,png,gif}");
const imgPath = "/src/assets/img/" + url;
if(!images[imgPath]){
    throw new Error("Image not found: " + imgPath);
}
//const img = import("/src/assets/img/" + url);
---
<div class="bg-img-div">
    <Image class="bg-image" src={images[imgPath]()} alt=""></Image>
    <div class="fg-content">
        <slot/>
    </div>
</div>

<style>
    .bg-img-div{
        position: relative;
        overflow:hidden;
        width: 100%;
        min-height: 3em;
        z-index:0;
    }

    .bg-image{
        position:absolute;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position:center;
        z-index: -1;
    }

    .fg-content{
        /* z-index: -1; */
    }
</style>
